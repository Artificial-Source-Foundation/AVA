# Estela Environment Variables
# Copy this file to .env and fill in your values

# OAuth Configuration (optional - enables OAuth login)
VITE_CODEX_CLIENT_ID=

# API Keys (optional - can also be set via Settings UI)
VITE_ANTHROPIC_API_KEY=
VITE_OPENROUTER_API_KEY=
VITE_OPENAI_API_KEY=

# Debug Mode (optional - enables verbose logging)
VITE_DEBUG=false
