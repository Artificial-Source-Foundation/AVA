{
  "name": "@estela/cli",
  "version": "0.1.0",
  "description": "Estela CLI - ACP-compatible AI coding assistant",
  "type": "module",
  "bin": {
    "estela": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:acp": "node dist/index.js --acp",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.13.1",
    "@estela/core": "workspace:*",
    "@estela/platform-node": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "~5.6.2"
  }
}
