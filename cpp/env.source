unset configure
unset make

function configure() { cmake . -B ../build -DCMAKE_VERBOSE_MAKEFILE=ON; }
function make() { /usr/bin/make -C ../build "$@"; }

alias linux00='../build/linux00'
alias linux01='../build/linux01'
alias linux02='../build/linux02'
alias linux03='../build/linux03'
alias linux04='../build/linux04'
alias linux05='../build/linux05'
alias linux06='../build/linux06'
