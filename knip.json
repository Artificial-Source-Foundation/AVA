{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["src/index.tsx", "src/App.tsx"],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": [
    "src-tauri/**",
    "src/stubs/**",
    "e2e/**",
    "docs/reference-code/**",
    "src/pages/DesignSystemPreview.tsx",
    "**/*.d.ts",
    "**/*.config.{js,ts}",
    "**/*.test.{ts,tsx}",
    "**/*.spec.{ts,tsx}"
  ],
  "ignoreDependencies": [],
  "ignoreBinaries": []
}
