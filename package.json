{
  "name": "ava",
  "version": "2.0.0",
  "description": "Multi-Agent AI Coding Assistant - Tauri desktop app with ACP support",
  "type": "module",
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "build:cli": "echo 'CLI is now a Rust binary — use cargo build'",
    "serve": "vite preview",
    "tauri": "tauri",
    "lint": "oxlint && eslint src/",
    "lint:fix": "biome check --write . && eslint src/ --fix",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "tsc --noEmit",
    "typecheck:all": "pnpm -r typecheck",
    "test": "vitest",
    "test:run": "vitest run",
    "test:cli": "vitest run cli/src/",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "verify:mvp": "bash scripts/testing/verify-mvp.sh",
    "docs:drift": "node scripts/docs/check-doc-drift.mjs",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "analyze": "ANALYZE=true vite build",
    "prepare": "lefthook install",
    "cli": "node cli/dist/index.js",
    "cli:acp": "node cli/dist/index.js --acp"
  },
  "license": "MIT",
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.12",
    "@kobalte/core": "^0.13.11",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-shell": "^2.3.4",
    "@tauri-apps/plugin-sql": "^2.3.1",
    "@tauri-apps/plugin-window-state": "^2.4.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "dompurify": "^3.3.1",
    "lucide-solid": "^0.563.0",
    "markdown-it": "^14.1.0",
    "solid-codemirror": "^2.3.1",
    "solid-js": "^1.9.3",
    "solid-motionone": "^1.0.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "node-pty"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@tauri-apps/cli": "^2",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.19.11",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.2",
    "eslint-plugin-oxlint": "^1.42.0",
    "eslint-plugin-solid": "^0.14.5",
    "jsdom": "^27.4.0",
    "knip": "^5.82.1",
    "lefthook": "^2.0.16",
    "oxlint": "^1.42.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.54.0",
    "vite": "^6.0.3",
    "vite-bundle-analyzer": "^1.3.2",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^4.0.18"
  }
}
