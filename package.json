{
  "name": "estela",
  "version": "0.1.0",
  "description": "Multi-Agent AI Coding Assistant - Tauri desktop app with ACP support",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "build:packages": "pnpm -r --filter './packages/*' build",
    "build:cli": "pnpm --filter @estela/cli build",
    "build:all": "pnpm build:packages && pnpm build:cli",
    "serve": "vite preview",
    "tauri": "tauri",
    "lint": "oxlint && eslint src/",
    "lint:fix": "biome check --write . && eslint src/ --fix",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "tsc --noEmit",
    "typecheck:all": "pnpm -r typecheck",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "analyze": "ANALYZE=true vite build",
    "prepare": "lefthook install",
    "cli": "node cli/dist/index.js",
    "cli:acp": "node cli/dist/index.js --acp"
  },
  "license": "MIT",
  "dependencies": {
    "@estela/core": "workspace:*",
    "@estela/platform-tauri": "workspace:*",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-shell": "^2.3.4",
    "@tauri-apps/plugin-sql": "^2.3.1",
    "solid-js": "^1.9.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@tauri-apps/cli": "^2",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.2",
    "eslint-plugin-oxlint": "^1.42.0",
    "eslint-plugin-solid": "^0.14.5",
    "jsdom": "^27.4.0",
    "knip": "^5.82.1",
    "lefthook": "^2.0.16",
    "oxlint": "^1.42.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.54.0",
    "vite": "^6.0.3",
    "vite-bundle-analyzer": "^1.3.2",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^4.0.18"
  }
}
