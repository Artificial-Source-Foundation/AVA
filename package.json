{
  "name": "delta9",
  "version": "0.1.0",
  "description": "Strategic AI Coordination for Mission-Critical Development - OpenCode Plugin",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "delta9": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./exports": {
      "types": "./dist/exports.d.ts",
      "import": "./dist/exports.js"
    },
    "./cli": {
      "import": "./dist/cli/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "postinstall": "node -e \"const fs=require('fs'),p='node_modules/@opencode-ai/plugin/dist/index.js';if(fs.existsSync(p)){const c=fs.readFileSync(p,'utf8');if(!c.includes('.js')){fs.writeFileSync(p,c.replace('./tool','./tool.js'))}}\""
  },
  "keywords": [
    "opencode",
    "ai",
    "agents",
    "multi-agent",
    "coding",
    "plugin",
    "orchestration"
  ],
  "author": "Andrés Godina",
  "license": "MIT",
  "dependencies": {
    "@opencode-ai/plugin": "*",
    "@opencode-ai/sdk": "^1.1.34",
    "commander": "^14.0.2",
    "date-fns": "^3.0.0",
    "js-yaml": "^4.1.1",
    "nanoid": "^5.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/delta9"
  },
  "bugs": {
    "url": "https://github.com/your-username/delta9/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
