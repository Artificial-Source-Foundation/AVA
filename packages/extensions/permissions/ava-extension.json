{
  "name": "ava-permissions",
  "version": "1.0.0",
  "description": "Safety & permission system — risk assessment, auto-approval, policy engine",
  "main": "src/index.ts",
  "builtIn": true,
  "enabledByDefault": true,
  "priority": 0,
  "capabilities": ["tool-middleware", "settings"],
  "settings": {
    "permissions.yolo": {
      "type": "boolean",
      "default": false,
      "description": "Auto-approve all tool calls"
    },
    "permissions.autoApproveReads": {
      "type": "boolean",
      "default": true,
      "description": "Auto-approve file reads"
    },
    "permissions.blockedPatterns": {
      "type": "array",
      "default": [],
      "description": "Glob patterns that are always blocked"
    }
  }
}
