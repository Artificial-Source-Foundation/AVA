{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "composite": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "resolveJsonModule": true,
    "paths": {
      "@ava/core-v2": ["../core-v2/src/index.ts"],
      "@ava/core-v2/agent": ["../core-v2/src/agent/index.ts"],
      "@ava/core-v2/llm": ["../core-v2/src/llm/index.ts"],
      "@ava/core-v2/tools": ["../core-v2/src/tools/index.ts"],
      "@ava/core-v2/extensions": ["../core-v2/src/extensions/index.ts"],
      "@ava/core-v2/platform": ["../core-v2/src/platform.ts"],
      "@ava/core-v2/bus": ["../core-v2/src/bus/index.ts"],
      "@ava/core-v2/config": ["../core-v2/src/config/index.ts"],
      "@ava/core-v2/session": ["../core-v2/src/session/index.ts"],
      "@ava/core-v2/logger": ["../core-v2/src/logger/index.ts"]
    }
  },
  "include": [
    "providers/**/*.ts",
    "permissions/**/*.ts",
    "tools-extended/**/*.ts",
    "prompts/**/*.ts",
    "context/**/*.ts",
    "agent-modes/**/*.ts",
    "hooks/**/*.ts",
    "validator/**/*.ts",
    "commander/**/*.ts",
    "memory/**/*.ts",
    "mcp/**/*.ts",
    "codebase/**/*.ts",
    "git/**/*.ts",
    "lsp/**/*.ts",
    "diff/**/*.ts",
    "focus-chain/**/*.ts",
    "instructions/**/*.ts",
    "models/**/*.ts",
    "scheduler/**/*.ts",
    "sandbox/**/*.ts",
    "skills/**/*.ts",
    "custom-commands/**/*.ts",
    "slash-commands/**/*.ts",
    "integrations/**/*.ts",
    "index.ts"
  ],
  "exclude": ["**/*.test.ts", "**/test-harness.ts", "**/__test-utils__/**", "dist", "node_modules"],
  "references": [{ "path": "../core-v2" }]
}
