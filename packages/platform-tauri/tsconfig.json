{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@ava/core-v2": ["../core-v2/src/index.ts"],
      "@ava/core-v2/*": ["../core-v2/src/*/index.ts", "../core-v2/src/*.ts"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "../core-v2" }]
}
