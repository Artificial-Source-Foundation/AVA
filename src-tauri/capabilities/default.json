{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "core:path:default",
    "dialog:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-close",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$HOME/.ava/**" },
        { "path": "$HOME/.estela/**" },
        { "path": "$CONFIG/ava/**" },
        { "path": "$DATA/ava/**" },
        { "path": "$CACHE/ava/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$HOME/.ava/**" },
        { "path": "$HOME/.estela/**" },
        { "path": "$CONFIG/ava/**" },
        { "path": "$DATA/ava/**" },
        { "path": "$CACHE/ava/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$HOME/.ava/**" },
        { "path": "$HOME/.estela/**" },
        { "path": "$CONFIG/ava/**" },
        { "path": "$DATA/ava/**" },
        { "path": "$CACHE/ava/**" }
      ]
    },
    {
      "identifier": "fs:allow-stat",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$HOME/.ava/**" },
        { "path": "$HOME/.estela/**" },
        { "path": "$CONFIG/ava/**" },
        { "path": "$DATA/ava/**" },
        { "path": "$CACHE/ava/**" }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$HOME/.ava/**" },
        { "path": "$HOME/.estela/**" },
        { "path": "$CONFIG/ava/**" },
        { "path": "$DATA/ava/**" },
        { "path": "$CACHE/ava/**" }
      ]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$HOME/.ava/**" },
        { "path": "$HOME/.estela/**" },
        { "path": "$CONFIG/ava/**" },
        { "path": "$DATA/ava/**" },
        { "path": "$CACHE/ava/**" }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$HOME/.ava/**" },
        { "path": "$HOME/.estela/**" },
        { "path": "$CONFIG/ava/**" },
        { "path": "$DATA/ava/**" },
        { "path": "$CACHE/ava/**" }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$HOME/.ava/**" },
        { "path": "$HOME/.estela/**" },
        { "path": "$CONFIG/ava/**" },
        { "path": "$DATA/ava/**" },
        { "path": "$CACHE/ava/**" }
      ]
    },
    "fs:allow-watch",
    "fs:allow-unwatch",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "sh", "cmd": "sh", "args": true },
        { "name": "bash", "cmd": "bash", "args": true },
        { "name": "git", "cmd": "git", "args": true },
        { "name": "rust-analyzer", "cmd": "rust-analyzer", "args": true },
        { "name": "typescript-language-server", "cmd": "typescript-language-server", "args": true },
        { "name": "pylsp", "cmd": "pylsp", "args": true },
        { "name": "gopls", "cmd": "gopls", "args": true },
        { "name": "jdtls", "cmd": "jdtls", "args": true }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "sh", "cmd": "sh", "args": true },
        { "name": "bash", "cmd": "bash", "args": true },
        { "name": "git", "cmd": "git", "args": true },
        { "name": "rust-analyzer", "cmd": "rust-analyzer", "args": true },
        { "name": "typescript-language-server", "cmd": "typescript-language-server", "args": true },
        { "name": "pylsp", "cmd": "pylsp", "args": true },
        { "name": "gopls", "cmd": "gopls", "args": true },
        { "name": "jdtls", "cmd": "jdtls", "args": true }
      ]
    },
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-show",
    "core:window:allow-create",
    "core:webview:allow-create-webview-window",
    "window-state:default"
  ]
}
